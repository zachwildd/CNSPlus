    "kyshumu": "tsx src/demo-kyshumu-poses.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
