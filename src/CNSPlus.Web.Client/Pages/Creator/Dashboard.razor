@page "/creator/dashboard"
@rendermode InteractiveWebAssembly
@layout CreatorLayout

<PageTitle>Creator · comicplus</PageTitle>

<h1 class="text-2xl font-semibold mb-2">Creator dashboard</h1>
<p class="text-neutral-600 mb-6">
    This page renders interactively in the browser via WebAssembly. The counter below
    proves WASM is alive; it will be replaced with real creator tools in phase 5.
</p>

<div class="rounded border border-neutral-200 bg-white p-4 inline-flex items-center gap-3">
    <button class="px-3 py-1 rounded bg-neutral-900 text-white text-sm" @onclick="() => _count++">
        Click me
    </button>
    <span class="text-sm text-neutral-700">count: @_count</span>
</div>

@code {
    private int _count;
}
