@page "/collection/{Slug}"
@layout PublicLayout
@inject ISeriesClient SeriesApi
@inject NavigationManager Nav

<SectionContent SectionName="head-extras">
    <style>
        main {
            background:
                linear-gradient(rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.9) 100%),
                url(https://img00.deviantart.net/6134/i/2011/172/4/b/eclipse_the_cyber_warrior_by_sheldon227-d3jm86w.jpg) fixed;
            background-size: cover;
        }
        .main-nav li.is-active {
            background:
                linear-gradient(rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.9) 100%),
                url(https://img00.deviantart.net/6134/i/2011/172/4/b/eclipse_the_cyber_warrior_by_sheldon227-d3jm86w.jpg) fixed;
            background-size: cover;
        }
    </style>
</SectionContent>

@if (_series is null)
{
    <PageTitle>Series · comicplus</PageTitle>
    <SectionContent SectionName="page-title">Series</SectionContent>
}
else
{
    <PageTitle>@_series.Title · comicplus</PageTitle>
    <SectionContent SectionName="page-title">@_series.Title By Sheldon Lloyd</SectionContent>

    <SectionContent SectionName="hero">
        <div class="comic-hero overflow-auto">
            <div class="comic-thumbnail-cover float-left"></div>
            <div class="overflow-auto">
                <div class="comic-heading overflow-auto">
                    <h3 class="float-right">Chapters (@(_comics?.Count ?? 0) Available)</h3>
                    @if (_comics is { Count: > 0 })
                    {
                        <h3><a href="/comic/@(_comics[0].Slug)">Start reading » @_series.Title</a></h3>
                    }
                </div>
                <div class="comic-details overflow-auto">
                    @if (!string.IsNullOrWhiteSpace(_series.Description))
                    {
                        <p>@_series.Description</p>
                    }
                    <h5 class="float-left">Rated (PG-13)</h5>
                    @if (!string.IsNullOrWhiteSpace(_series.UpdateSchedule))
                    {
                        <h5 class="float-right">Updates: @_series.UpdateSchedule</h5>
                    }
                </div>
            </div>
        </div>
    </SectionContent>

    <SectionContent SectionName="aside">
        <aside class="float-right aside">
            <div class="ad container">
                <span>Advertisement</span>
                <div class="placeholder"></div>
            </div>
            <div class="blog-posts container">
                <h3>Blog Posts</h3>
                <ul>
                    <li><a>Title 1</a></li>
                    <li><a>Title 2</a></li>
                    <li><a>Title 3</a></li>
                    <li><a>Title 4</a></li>
                    <li><a>Title 5</a></li>
                </ul>
            </div>
        </aside>
    </SectionContent>

    @if (_comics is not null)
    {
        @foreach (var (comic, index) in _comics.Select((c, i) => (c, i)))
        {
            <div class="archive-comic container cf flexbox">
                <div class="comic-thumbnail-progress"
                     style="background: linear-gradient(180deg, rgba(54,91,135,1) 0%, rgba(54,91,135,1) 25%, rgba(255,255,255,1) 25%);">
                    <div>25% Complete</div>
                </div>
                <div class="comic-thumbnail-cover float-left"></div>
                <div class="archive-comic-action float-right">
                    <a href="/comic/@comic.Slug" class="button">Read</a>
                </div>
                <div class="archive-comic-content overflow-auto">
                    <div class="archive-comic-heading">
                        <h3>@(comic.Title ?? $"Chapter {comic.PositionInSeries ?? index + 1}")</h3>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(comic.Caption))
                    {
                        <p class="archive-comic-description">@comic.Caption</p>
                    }
                </div>
            </div>
        }
    }

    <div class="character-appearances">
        <div class="character-appearances-header">
            <div class="float-right">
                <a class="character-appearances-previous pointer">&laquo;</a>
                <a class="character-appearances-next pointer">&raquo;</a>
            </div>
            <h3>Characters in this series/collection</h3>

            <div class="character-appearances-nav"></div>
            <div class="character-appearances-list custom-scrollbar">
                <ul>
                    @* Phase 4 will wire this to a Characters_ListByUniverse endpoint. *@
                    <li><div class="comic-thumbnail-cover float-left"></div></li>
                    <li><div class="comic-thumbnail-cover float-left"></div></li>
                    <li><div class="comic-thumbnail-cover float-left"></div></li>
                    <li><div class="comic-thumbnail-cover float-left"></div></li>
                    <li><div class="comic-thumbnail-cover float-left"></div></li>
                </ul>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? Slug { get; set; }

    private CNSPlus.Shared.Series? _series;
    private IReadOnlyList<CNSPlus.Shared.Comic>? _comics;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _series = await SeriesApi.GetBySlugAsync(Slug ?? "");
            _comics = await SeriesApi.ListComicsAsync(Slug ?? "");
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            Nav.NavigateTo("/not-found");
        }
    }
}
